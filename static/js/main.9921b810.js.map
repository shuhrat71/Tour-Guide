import styled from "styled-components";

export const UltimateTour__Wrapper = styled.section`
  width: 100%;
  padding: 20px;
  border-radius: 20px;
  margin-top: 50px;
  background-color: white;
`;
export const UltimateTitle = styled.div`
  width: 100%;
  display: flex;
  justify-content: center;
  margin-bottom: 60px;
  h1 {
    font-size: 40px;
    font-weight: bold;
    margin-bottom: 20px;
  }
`;
export const UltimateCardWrapper = styled.div`
  width: 100%;
  display: flex;
  justify-content: center;
  align-items: center;
  flex-wrap: wrap;
  gap: 20px;
`;
export const CardPrice = styled.div`
  width: 100%;
  display: flex;
  justify-content: space-between;
  align-items: center;
`;
